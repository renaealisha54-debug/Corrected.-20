// In your InputMethodService class
val dictionary = mapOf(
    "bitch" to "baby",
    "stupid" to "lovely",
    "fuck you" to "i love you"
)

fun applyCorrection(text: String): String {
    var corrected = text
    dictionary.forEach { (bad, good) ->
        corrected = corrected.replace(bad, good, ignoreCase = true)
    }
    return corrected
}

